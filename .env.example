# Frovo Manager - Environment variables
# Copy this file to .env (and to your hosting / CI secrets)
# All vars must start with VITE_ to be exposed to the client bundle.

# Required: Supabase project URL (e.g. https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Required: Supabase ANON public key (NOT service role)
VITE_SUPABASE_ANON_KEY=

# Optional: enable verbose dashboard debug banner (1 to enable)
VITE_DASHBOARD_DEBUG=

# --- Finance AI (Supabase Edge Function secrets, NOT client env) ---
# Deploy: supabase functions deploy finance-ai-chat
# Set secrets in Supabase Dashboard → Edge Functions → finance-ai-chat → Secrets:
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini   (optional)